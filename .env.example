# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://swlfyyiupzsbiuinepla.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── WhatsApp / Baileys ───────────────────────────────────────────────────────
# The client_id of the "default" tenant used when booting in single-tenant mode.
# In multi-tenant production, each client row is loaded from the DB.
DEFAULT_CLIENT_ID=your-client-uuid-here

# ─── Anti-ban ─────────────────────────────────────────────────────────────────
# Min/max typing delay in ms before any outgoing message is sent
TYPING_DELAY_MIN_MS=1000
TYPING_DELAY_MAX_MS=3000

# Hard cap: max unique conversations per client per day (enforcement TBD)
MAX_DAILY_CONVERSATIONS=200

# ─── Queue ────────────────────────────────────────────────────────────────────
OUTGOING_QUEUE_NAME=whatsapp-outgoing

# ─── QR Pairing Server ────────────────────────────────────────────────────────
# HTTP server port for the browser-scannable QR code page.
# On Railway, expose this port and open /qr in your browser to pair.
QR_SERVER_PORT=3001

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com
# REQUIRED — the app will fast-fail on startup if this is missing.
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: override the model. Default is gemini-2.0-flash (cheap + fast).
GEMINI_MODEL=gemini-2.0-flash

# ─── AI / OpenAI ──────────────────────────────────────────────────────────────
# REQUIRED — the app will fast-fail on startup if this is missing.
OPENAI_API_KEY=your-openai-api-key-here
# Optional: override the model. Default is gpt-4o-mini (cheap + fast).
OPENAI_MODEL=gpt-4o-mini

# ─── Negotiation guardrails ───────────────────────────────────────────────────
# Number of price negotiation rounds before the AI holds firm at min_price.
MAX_NEGOTIATION_ROUNDS=3
